# ─────────────────────────────────────────────────────
#  BACKEND — Azure App Service Environment Variables
#  Set all of these in:
#  Azure Portal → App Service (backend) → Configuration → Application Settings
# ─────────────────────────────────────────────────────

NODE_ENV=production
PORT=8080

# ─── Database (Azure PostgreSQL) ────────────────────
# Get this from: Azure Portal → PostgreSQL → Connection strings
DATABASE_URL=postgresql://USERNAME:PASSWORD@YOUR-SERVER.postgres.database.azure.com/postgres?sslmode=require

# ─── Blockchain ─────────────────────────────────────
BSC_RPC_URL=https://bsc-dataseed.binance.org
FACTORY_ADDRESS=0xbe1E871a4578Cf98c7791C7Cd308d1855A9a0494
LIQUIDITY_MANAGER_ADDRESS=0x676c96A6dE82474674ECa28B75f93e90021908da
BONDING_CURVE_ADDRESS=0xF13184CB8026DcbCD6832cA2DBDdd928077Cd619
DIRECT_FACTORY_ADDRESS=0xeEBC10420F486F8357c2efaBd6F5F44Ac9a568a9
PRIVATE_KEY=YOUR_PRIVATE_KEY
FEE_WALLET=0xa5a5A2B6886A54AA864C82d69AfE9667FEB8C0dE
TREASURY_BTC=bc1q8r59y8wzcy9rku4ssvwqmvqpsnum82kgnzpgna
TREASURY_SOL=9wnaUDycrcRHtwPvFoX8egKxGyq2HPaTc7rbKf6dXsaZ
TREASURY_TRON=TFnc75NNuxScqQVjdmQLSUzLc4RJw4cZcq

# ─── CORS — Set to your frontend Azure URL ──────────
ALLOWED_ORIGINS=https://YOUR-FRONTEND-APP.azurewebsites.net

# ─── Price / Market APIs ────────────────────────────
COINMARKETCAP_API_KEY=YOUR_CMC_KEY
COINGECKO_API_KEY=YOUR_COINGECKO_KEY

# ─── IPFS / Pinata ──────────────────────────────────
PINATA_API_KEY=YOUR_PINATA_KEY
PINATA_API_SECRET=YOUR_PINATA_SECRET
PINATA_JWT=YOUR_PINATA_JWT

# ─── GitHub ─────────────────────────────────────────
GITHUB_TOKEN=YOUR_GITHUB_TOKEN
GITHUB_USERNAME=YOUR_GITHUB_USERNAME

# ─── Blockchain Explorers ───────────────────────────
BSCSCAN_API_KEY=YOUR_BSCSCAN_KEY

# ─── AI Services ────────────────────────────────────
OPENAI_API_KEY=YOUR_OPENAI_KEY
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY
