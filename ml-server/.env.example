# ============================================
# antigraVITY ML Engine — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys

# Anthropic API Key — get free at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CoinGecko API Key — get free at coingecko.com/en/api
COINGECKO_API_KEY=your_coingecko_api_key_here

# Twitter Bearer Token — optional, for social sentiment
# Get free at developer.twitter.com
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Server port
PORT=3001

# Your antigraVITY frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
